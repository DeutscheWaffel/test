  "authors": [
    "Developer"
  ],
  "contact": {
    "homepage": "https://github.com/yourusername/native-fsr-mod"
  },
  "license": "MIT",
  "icon": "assets/native-fsr-mod/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.githubuser.nativefsr.NativeFSRMod"
    ]
  },
  "mixins": [
    "native-fsr-mod.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "fabric-api": "*"
